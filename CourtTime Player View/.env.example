# Database connection (Supabase PostgreSQL — use Shared Pooler connection string)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT].pooler.supabase.com:6543/postgres

# JWT secret for authentication (required — generate a random string)
JWT_SECRET=your-random-secret-here

# Frontend API base URL (optional — defaults to localhost:3001 in dev, same-origin in production)
# VITE_API_BASE_URL=http://localhost:3001

# Server port (optional — defaults to 3001)
# PORT=3001

# Resend email service (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=CourtTime <noreply@yourdomain.com>

# App URL (used for CORS, password reset links, etc.)
APP_URL=https://your-app.onrender.com

# Stripe (payment processing — use test keys during development)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Support console password
SUPPORT_PASSWORD=your-support-password-here

# Node options (required on Render for Supabase IPv4 compatibility)
NODE_OPTIONS=--dns-result-order=ipv4first
