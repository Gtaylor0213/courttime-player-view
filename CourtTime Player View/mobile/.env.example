# API base URL (no trailing slash). Optional — see resolution order in mobile/src/api/client.ts

# Force a specific API (overrides everything, including tunnel + production default):
# EXPO_PUBLIC_API_URL=https://www.courttimeapp.com

# Web app origin for "Register your facility" (opens /register/facility in the browser).
# Optional — defaults from API URL (production: same host; local API :3001 -> Vite :5173).
# EXPO_PUBLIC_WEB_URL=https://www.courttimeapp.com

# Optional: override the baked-in production default from app.config.js (forks / staging):
# EXPO_PUBLIC_PRODUCTION_API_URL=https://staging.example.com

# Optional: only needed if you want a manual fallback for Expo push token projectId
# outside of an EAS-linked build/dev client.
# EXPO_PUBLIC_EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Local Express only: same Wi‑Fi + Expo LAN (not tunnel). Host comes from Metro; port:
# EXPO_PUBLIC_API_PORT=3001

# Expo Go + **tunnel**: unset EXPO_PUBLIC_API_URL to use production from app.config.js
# (https://www.courttimeapp.com). Tunnel cannot reach your laptop’s localhost/LAN API.

# Public Sentry DSN used by the mobile app at runtime:
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
#
# Optional: allow dev builds to send Sentry events for manual verification.
# Leave unset to keep local development quiet by default.
# EXPO_PUBLIC_SENTRY_ENABLE_IN_DEV=1
#
# Optional build-time source map upload settings for the Expo config plugin:
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-mobile-project-slug
# SENTRY_AUTH_TOKEN=your-auth-token
# SENTRY_URL=https://sentry.io/

# Local backend from repo root: `npm run server` or `npm run dev` in "CourtTime Player View".
