# API base URL (no trailing slash). Optional in __DEV__ — the app can derive the host
# from Metro's hostUri so Expo Go on a phone hits your computer on the same Wi‑Fi.

# Explicit override (simulator, tunnel, or non-default machine):
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3001

# If your API is not on port 3001, set the port only (hostname still from Metro in dev):
# EXPO_PUBLIC_API_PORT=3002

# Production (Render, etc.):
# EXPO_PUBLIC_API_URL=https://your-app.onrender.com

# Notes:
# - Run the API from the repo: `npm run server` or `npm run dev` (from "CourtTime Player View").
# - Phone + Expo Go: same Wi‑Fi as your Mac/PC; server listens on 0.0.0.0 by default.
# - If you use Expo "Tunnel", set EXPO_PUBLIC_API_URL to your LAN IP manually.
# - macOS may prompt to allow incoming connections on first use.
